# Google OAuth credentials (for @example.com identity validation)
# Store in GCP Secret Manager: gsheets-oauth-id, gsheets-oauth-secret
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret

# Write allowlist — comma-separated @example.com emails that receive write tools.
# All other authenticated @example.com users get read-only access.
# Update and redeploy to add/remove write access.
WRITE_ALLOWLIST=user@example.com,user@example.com,user@example.com,user@example.com,user@example.com,user@example.com,user@example.com,user@example.com,user@example.com,user@example.com,user@example.com,user@example.com,user@example.com,user@example.com,user@example.com

# Server settings
PORT=8080
ALLOWED_DOMAIN=example.com

# Update this after first Cloud Run deploy — used in OAuth metadata responses.
SERVER_URL=https://your-service.example.com
